# 大模型api_key配置，不使用可以不进行配置
DEEPSEEK_KEY=sk-xxx
ERNIE_KEY=sk-xxx
ARK_KEY=sk-xxx
QWEN_KEY=sk-xxx
MINIMAX_KEY=sk-xxx
KIMI_KEY=sk-xxx
GLM_KEY=sk-xxx
QIANFAN_KEY=sk-xxx
MIMO_KEY=sk-xxx

# 大模型 API Base URL（可选，不填则使用下方默认地址）
KIMI_BASE_URL=https://api.moonshot.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 阿里云 DashScope（灵积模型服务） 必填 用于Embedding
DASHSCOPE_API_KEY=sk-xxx

# 智谱互联网搜索 必填 用于websearch
ZAI_KEY=xxx

# 阿里云 AK/SK  必填 用于文件内容解析 + 邮件推送
ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx

# 阿里云智能语音交互 - 一句话识别（语音输入，可选）
# AK/SK 需 RAM 策略 AliyunNLSFullAccess
NLS_APP_KEY=xxx

# 阿里云邮件推送 DM 服务（必填，用于邮箱验证码登录）
# 详见 https://help.aliyun.com/document_detail/29440.html
ALIYUN_DM_ENDPOINT=dm.aliyuncs.com
# 已在 DM 控制台验证过的发信邮箱（必填）
ALIYUN_DM_ACCOUNT_NAME=xxx@your-domain.com
# 发件人显示名（可选）
ALIYUN_DM_FROM_ALIAS=Soulprout
# 验证码有效期（秒，默认 600 = 10 分钟）
EMAIL_CODE_TTL_SECONDS=600
# 同一邮箱再次请求验证码的最小间隔（秒，默认 60）
EMAIL_CODE_RESEND_SECONDS=60

# Soulprout模式AI配置
SOULPROUT_MODEL_SOURCE=deepseek
SOULPROUT_MODEL=deepseek-v4-pro

# 高级模型: 注重精度忽略速度
PRO_MODEL_SOURCE=deepseek
PRO_MODEL=deepseek-v4-pro

# 快速模型: 注重速度
FLASH_MODEL_SOURCE=deepseek
FLASH_MODEL=deepseek-v4-flash

# JWT密钥
JWT_SECRET_KEY=xxx

# hybrid_search 混合检索配置
# dense=embedding 向量权重，sparse=BM25 稀疏检索权重（默认 0.7 / 0.3）
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3
# 融合分阈值：score >= 该值视为可匹配（默认 0.6）
HYBRID_SEARCH_SCORE=0.6
# 记忆召回 Top-K 与分数阈值（可选，默认复用 HYBRID_SEARCH_SCORE）
# MEMORY_RECALL_TOP_K=10
# MEMORY_RECALL_SCORE=0.6


# 部署模式：private=本地私有化；saas=多租户 SaaS
DEPLOYMENT_MODE=private

# SSO 开关及服务器IP
ENABLE_SSO_LOGIN=true
# 填写服务器公网IP
FRONTEND_URL=http://1.1.1.1:80
