# 大模型api_key配置，不使用可以不进行配置
DEEPSEEK_KEY=sk-xxx
ERNIE_KEY=sk-xxx
ARK_KEY=sk-xxx
QWEN_KEY=sk-xxx
MINIMAX_KEY=sk-xxx
KIMI_KEY=sk-xxx
GLM_KEY=sk-xxx
QIANFAN_KEY=sk-xxx
MIMO_KEY=sk-xxx

# 阿里云 DashScope（灵积模型服务） 必填 用于Embedding
DASHSCOPE_API_KEY=sk-xxx

# 智谱互联网搜索 必填 用于websearch
ZAI_KEY=xxx

# 阿里云 AK/SK  必填 用于文件内容解析 + 邮件推送
ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx

# 阿里云邮件推送 DM 服务（必填，用于邮箱验证码登录）
# 详见 https://help.aliyun.com/document_detail/29440.html
ALIYUN_DM_ENDPOINT=dm.aliyuncs.com
# 已在 DM 控制台验证过的发信邮箱（必填）
ALIYUN_DM_ACCOUNT_NAME=xxx@your-domain.com
# 发件人显示名（可选）
ALIYUN_DM_FROM_ALIAS=Soulprout
# 验证码有效期（秒，默认 600 = 10 分钟）
EMAIL_CODE_TTL_SECONDS=600
# 同一邮箱再次请求验证码的最小间隔（秒，默认 60）
EMAIL_CODE_RESEND_SECONDS=60

# 对话摘要AI配置 必填 建议响应速度快
ABSTRACT_MODEL_SOURCE=ark
ABSTRACT_MODEL=doubao-seed-1-6-flash-250828

# 是否开启深度思考配置 必填 建议兼顾响应速度和质量
DEEPTHINK_MODEL_SOURCE=ark
DEEPTHINK_MODEL=doubao-seed-2-0-lite-260215

# 规划AI配置 必填 建议质量高
PLAN_MODEL_SOURCE=ark
PLAN_MODEL=doubao-seed-2-0-pro-260215

# compact压缩AI配置 必填 建议兼顾响应速度和质量
SHORT_MEMORY_MODEL_SOURCE=ark
SHORT_MEMORY_MOEDEL=doubao-seed-2-0-lite-260215

# collapse压缩AI配置 必填 必须满足长上下文
COLLAPSE_MODEL_SOURCE=ark
COLLAPSE_MODEL=doubao-seed-2-0-lite-260215

# skills概括AI配置 必填 建议优先响应速度
SKILLS_ABSTRACT_MODEL_SOURCE=ark
SKILLS_ABSTRACT_MODEL=doubao-seed-2-0-mini-260215

# Soulprout模式AI配置
SOULPROUT_MODEL_SOURCE=kimi
SOULPROUT_MODEL=kimi-k2.6

# JWT密钥
JWT_SECRET_KEY=xxx

# hybrid_search 混合检索配置
# dense=embedding 向量权重，sparse=BM25 稀疏检索权重（默认 0.7 / 0.3）
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3
# 融合分阈值：score >= 该值视为可匹配（默认 0.6）
HYBRID_SEARCH_SCORE=0.6
# 记忆召回 Top-K 与分数阈值（可选，默认复用 HYBRID_SEARCH_SCORE）
# MEMORY_RECALL_TOP_K=10
# MEMORY_RECALL_SCORE=0.6


# 以下为企业部署时使用
# Docker部署时的本地内网IP
DOCKER_SERVER_HOST=172.17.0.1

# SSO 开关及服务器IP
ENABLE_SSO_LOGIN=true
# 填写服务器公网IP
FRONTEND_URL=http://1.1.1.1:80
