{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soulprout Gateway",
  "version": "0.1.0",
  "identifier": "com.soulprout.gateway",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:8082",
    "frontendDist": "http://localhost:8082"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soulprout Gateway",
        "width": 600,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "http://localhost:8082"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/gateway"
    ],
    "resources": []
  }
}
