# ─── Milvus ───────────────────────────────────────────────────────────────────
# 本地 Milvus Standalone
MILVUS_URI=http://localhost:19530
# Milvus Cloud / 需要鉴权时填写 token；本地不需要可留空
MILVUS_TOKEN=

# ─── Embedding ────────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-xxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536

# ─── 预设 Collection 名称 ──────────────────────────────────────────────────────
VDB_KB_COLLECTION=kb_collection
VDB_SKILL_COLLECTION=skill_collection
VDB_MEMORY_COLLECTION=memory_collection
VDB_MCP_COLLECTION=mcp_collection

# ─── 服务监听 ──────────────────────────────────────────────────────────────────
VDB_HOST=0.0.0.0
VDB_PORT=8888

# ─── hybrid_search 混合检索权重 ───────────────────────────────────────────────
# dense=embedding 向量权重，sparse=BM25 稀疏检索权重（默认 0.7 / 0.3）
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3
