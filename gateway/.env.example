# ============================================================
# 微信客服（WeCom Customer Service）配置
# 登录 https://work.weixin.qq.com/wework_admin/frame#kf 管理
# ============================================================

# 企业 ID（在「我的企业 → 企业信息」中获取）
WECOM_CORP_ID=your_corp_id

# 微信客服专用 Secret
# 在「客户联系 → 微信客服 → 帮助 → API」中获取
WECOM_KF_SECRET=your_kf_secret

# 回调配置中的 Token
# 在「微信客服 → API → 回调配置」中自定义
WECOM_KF_CALLBACK_TOKEN=your_callback_token

# 回调配置中的 EncodingAESKey（43位，同上位置生成）
WECOM_KF_ENCODING_AES_KEY=your_encoding_aes_key_43_chars

# 回调接收地址路径（默认 /wecom/kf/callback，需与企业微信后台配置一致）
# WECOM_KF_CALLBACK_PATH=/wecom/kf/callback

# HTTP 服务监听地址与端口（默认 0.0.0.0:8091）
# WECOM_KF_HOST=0.0.0.0
# WECOM_KF_PORT=8091
