# ============================================================
# Soulprout Gateway 部署配置
#
# ⚠️  用户个人信息（微信账号、飞书/企业微信 Bot 凭证、Agent 地址、访问令牌等）
#     请通过管理界面（http://localhost:8082）进行配置，
#     不要在此文件中填写，配置会自动保存到 gateway_data/ 目录。
# ============================================================

# ── 管理 Web 服务监听地址与端口 ───────────────────────────────
# 仅在需要修改默认值时取消注释
# GATEWAY_WEB_HOST=0.0.0.0
# GATEWAY_WEB_PORT=8082

# ── 飞书（可选 headless，通常通过 Web UI 配置）────────────────
# 实现参考：https://github.com/NousResearch/hermes-agent
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=secret_xxx
# FEISHU_DOMAIN=feishu

# ── 企业微信 AI Bot（可选 headless，通常通过 Web UI 配置）──────
# 实现参考：https://github.com/NousResearch/hermes-agent（gateway/platforms/wecom.py）
# WECOM_BOT_ID=bot_xxx
# WECOM_SECRET=secret_xxx
# WECOM_WEBSOCKET_URL=wss://openws.work.weixin.qq.com
